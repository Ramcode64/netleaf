# ─── Local mode (default: on) ────────────────────────────────────────────────
# Set to true to skip all auth — hit the API directly with no key
LOCAL_MODE=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Security (SSRF guard) ────────────────────────────────────────────────────
# The scraper refuses to fetch private / loopback / link-local / cloud-metadata
# addresses by default. Set to true ONLY for trusted local dev where you want to
# scrape localhost or LAN hosts. NEVER enable on a public/cloud deployment.
ALLOW_PRIVATE_IPS=false
# Max characters stored/returned per scraped page format (memory + DB guard).
MAX_CONTENT_CHARS=5000000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://netleaf:netleaf_dev@localhost:5432/netleaf

# ─── Redis (crawl job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM Providers (all optional — configure whichever you have) ──────────────
# For /v1/extract endpoint. If none set, Ollama (local) is used by default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# ─── Search (optional — for /v1/search endpoint) ─────────────────────────────
# Free tier: https://brave.com/search/api/ (2000 queries/month free)
BRAVE_API_KEY=

# ─── Legacy key migration (one-time) ─────────────────────────────────────────
# If you had API_KEYS set before, paste them here to migrate them to the DB
LEGACY_API_KEYS=

# ─── Registration ────────────────────────────────────────────────────────────
# Set to true after creating your account to prevent new signups on this instance.
DISABLE_REGISTRATION=false

# ─── Web app (apps/web) — Auth.js v5 ─────────────────────────────────────────
# v5 reads AUTH_SECRET / AUTH_URL (NOT the v4 NEXTAUTH_* names).
# AUTH_SECRET is REQUIRED — docker compose up fails until it is set.
# Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3001
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Webhook signing ─────────────────────────────────────────────────────────
# Optional but strongly recommended: set a random secret so webhook receivers
# can verify the X-Netleaf-Signature header on crawl.completed events.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ─── Docker passwords ─────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is REQUIRED — docker compose up fails until it is set.
# Generate a strong value: openssl rand -hex 20
POSTGRES_PASSWORD=
# Set a Redis password to prevent unauthenticated access from other containers.
# Leave blank for local dev only (Docker bridge network provides isolation).
REDIS_PASSWORD=
