# Web dashboard environment

# Shared PostgreSQL with the API (same DATABASE_URL)
DATABASE_URL=postgresql://netleaf:netleaf@localhost:5432/netleaf

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-32-byte-secret

# Base URL of the Netleaf API (public — used by the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional Google OAuth (leave unset to disable the Google sign-in button)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
