{
  "name": "@netleaf/api",
  "version": "0.1.0",
  "description": "Netleaf API server — web scraping, crawling, extraction",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "bullmq": "^5.15.0",
    "cheerio": "^1.0.0",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "openai": "^4.67.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.0",
    "postgres": "^3.4.5",
    "turndown": "^7.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.29.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
