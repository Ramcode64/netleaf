PORT=3000
NODE_ENV=development

# Set to true to skip API key auth (personal/local use only — never in shared deployments)
LOCAL_MODE=false

# Redis (required for crawl job queue)
REDIS_URL=redis://localhost:6379

# API Keys — comma-separated list of valid keys
# Generate with: openssl rand -hex 32
API_KEYS=your-secret-api-key-here

# Scraper settings
BROWSER_POOL_SIZE=3
DEFAULT_TIMEOUT_MS=30000
MAX_CRAWL_PAGES=100

# CORS — comma-separated allowed origins, or * to allow all (default: deny cross-origin)
# CORS_ORIGIN=http://localhost:3001,https://your-domain.com

# Ollama (local LLM, no API key needed)
OLLAMA_URL=http://localhost:11434
