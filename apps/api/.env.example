PORT=3000
NODE_ENV=development

# Default: bypass auth so `docker compose up` works without seeding API keys.
# The startup guard refuses LOCAL_MODE=true + NODE_ENV=production, so shared
# deployments are still safe. Flip to false + provision API_KEYS for prod.
LOCAL_MODE=true

# Redis (required for crawl job queue)
REDIS_URL=redis://localhost:6379

# API Keys — comma-separated list of valid keys
# Generate with: openssl rand -hex 32
API_KEYS=your-secret-api-key-here

# Scraper settings
BROWSER_POOL_SIZE=3
DEFAULT_TIMEOUT_MS=30000
MAX_CRAWL_PAGES=100

# CORS — comma-separated allowed origins, or * to allow all (default: deny cross-origin)
# CORS_ORIGIN=http://localhost:3001,https://your-domain.com

# Ollama (local LLM, no API key needed)
OLLAMA_URL=http://localhost:11434

# Webhook signing — if set, outgoing webhooks include X-Netleaf-Signature: sha256=<hmac>
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=

# Redis password — if set, also update REDIS_URL to redis://:password@localhost:6379
# REDIS_PASSWORD=
